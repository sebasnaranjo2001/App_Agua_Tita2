  m_Script: {fileID: 11500000, guid: b839579855b47844499ec75b87720074, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::QuizManager
  preguntas:
  - pregunta: "\xBFCu\xE1l es la mejor forma de ahorrar  agua al cepillarse los dientes? "
    respuestas:
    - "Usar m\xE1s agua para limpiar mejor"
    - "Cepillarse m\xE1s rapido sin cerrar la llave"
    - Usar un vaso con agua
    respuestaCorrecta: 2
    imagen: {fileID: -6634870019379800329, guid: d64965156f00eaf439b41103df30183d, type: 3}
  - pregunta: "\xBFQu\xE9 acci\xF3n ayuda m\xE1s a reducir el consumo de agua en
      la ducha? "
    respuestas:
    - Tomar duchas largas
    - 'Cerrar la llave mientras me enjabono '
    - Usar agua muy caliente
    respuestaCorrecta: 1
    imagen: {fileID: 7631065013208611830, guid: b4d21c300a7d1394c87bb5354a62eebe, type: 3}
  - pregunta: "Cu\xE1l de estas pr\xE1cticas es m\xE1s sostenible para regar plantas?"
    respuestas:
    - "Regar al mediod\xEDa"
    - Usar manguera sin control
    - "Regar en la noche o temprano en la ma\xF1ana"
    respuestaCorrecta: 2
    imagen: {fileID: 4083244196564083931, guid: 9c5f07065cb728442836aee7b996fdd0, type: 3}
  - pregunta: "\xBFQu\xE9 se debe hacer si se detecta una fuga de agua en casa? "
    respuestas:
    - Repararla lo antes posible
    - "Usar m\xE1s agua para"
    - Ingnorarla
    respuestaCorrecta: 0
    imagen: {fileID: 2157100433164358582, guid: c90d8b76eaff2a3459cf82e72075e544, type: 3}
  - pregunta: "\xBFCu\xE1l es la mejor manera de usar la lavadora? "
    respuestas:
    - Usar con poca ropa
    - Usarla en la noche
    - Usarla con carga llena
    respuestaCorrecta: 2
    imagen: {fileID: 4794123611389575039, guid: fcdab764c2a9cb34fab36450ce38062b, type: 3}
  textoPregunta: {fileID: 2113703432}
  imagenPregunta: {fileID: 1607499537}
